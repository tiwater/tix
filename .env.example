# TiClaw Environment Configuration

# Assistant Settings
ASSISTANT_NAME="Shaw"
ASSISTANT_HAS_OWN_NUMBER="false"

# Coding CLI Configuration
# Options: 
# - gemini: Gemini CLI (Recommended for Gemini Advanced subscriptions)
# - claude: Anthropic Claude Code CLI
TC_CODING_CLI="gemini"

# LLM Configuration
# Set your model here (provider-agnostic name)
# Default: anthropic/claude-3.5-sonnet
TC_MODEL="anthropic/claude-sonnet-4.6"

# LLM Provider: OpenRouter (Default)
# Just set your key here. TiClaw automatically handles the base URL and model defaults.
OPENROUTER_API_KEY="your-openrouter-api-key"

# To use Anthropic directly, set this and comment out OpenRouter settings:
# ANTHROPIC_API_KEY="your-anthropic-api-key"

# To use Google Gemini, set this:
# GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# Discord Bot Token (Required for Discord command adapter)
TC_DISCORD_TOKEN="your-discord-bot-token"

# Proxy Settings (Optional, useful for regions like China)
# HTTPS_PROXY="http://127.0.0.1:7890"
# HTTP_PROXY="http://127.0.0.1:7890"

# Performance & Concurrency
MAX_CONCURRENT_CONTAINERS="5"
CONTAINER_TIMEOUT="1800000"
IDLE_TIMEOUT="1800000"

# Preview URL Pattern (Optional)
# Supports ${PR_NUMBER} placeholder for dynamic PR deployment links
# TC_PREVIEW_URL_PATTERN="https://ticos-pr-${PR_NUMBER}.onrender.com"

# Log Level: debug, info, warn, error
LOG_LEVEL="info"

# Mind governance
# Comma-separated sender IDs that can override locked mind via natural conversation
# Example: MIND_ADMIN_USERS="ou_9ea1d42fac15bf224aae1ad3370bed39,dc:user:12345"
MIND_ADMIN_USERS=""

# strict | admin_override
MIND_LOCK_MODE="admin_override"
