{
  "name": "ticlaw",
  "version": "1.2.1",
  "description": "Mind builder. Multi-channel, personality & memory evolution, lightweight, secure.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:web": "pnpm --filter @ticlaw/web run dev -- --open",
    "dev:all": "concurrently \"pnpm run dev\" \"pnpm run dev:web\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@anthropic-ai/sdk": "^0.78.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@supabase/supabase-js": "^2.47.0",
    "@ticlaw/hub": "workspace:^",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.25.1",
    "https-proxy-agent": "^7.0.6",
    "js-yaml": "^4.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "undici": "^7.22.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs"
    ]
  }
}