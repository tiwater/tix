{
  "name": "ticlaw",
  "version": "1.3.0",
  "description": "Mind builder. Multi-channel, personality & memory evolution, lightweight, secure.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "skills",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "auth": "tsx src/whatsapp-auth.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:web": "pnpm --filter web run dev",
    "dev:all": "pnpm --filter @ticlaw/hub run build && concurrently \"pnpm --filter web run dev\" \"sleep 2 && pnpm run dev\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@anthropic-ai/sdk": "^0.78.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@supabase/supabase-js": "^2.47.0",
    "axios": "^1.6.0",
    "cron-parser": "^5.5.0",
    "dingtalk-stream": "^2.1.0",
    "discord.js": "^14.25.1",
    "https-proxy-agent": "^7.0.6",
    "js-yaml": "^4.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "undici": "^7.22.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
