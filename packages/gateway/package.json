{
  "name": "@tix/gateway",
  "version": "0.1.0",
  "type": "module",
  "description": "Tix Gateway — WebSocket multiplexer relay that accepts inbound agent computer connections. Embeddable by Supen or any controller platform.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node --env-file=../../.env dist/start.js",
    "dev": "tsc --watch & sleep 2 && node --env-file=../../.env --watch dist/start.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "typescript": "^5.9.3"
  }
}
