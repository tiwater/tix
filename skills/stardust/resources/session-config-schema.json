{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stardust Session Update Event",
  "description": "Configuration schema for session.update events sent to the Stardust realtime service.",
  "type": "object",
  "required": ["event_id", "type", "session"],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique event identifier"
    },
    "type": {
      "type": "string",
      "enum": ["session.update", "session.create"],
      "description": "Event type"
    },
    "session": {
      "type": "object",
      "properties": {
        "agent_id": {
          "type": "string",
          "description": "Agent ID — when set, server resolves all other config from Agent ConfigServer"
        },
        "model": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["tiwater", "customization", "aliyun", "bytedance", "qcloud", "baidu", "deepseek", "zai", "openai"],
              "default": "tiwater"
            },
            "name": {
              "type": "string",
              "description": "Model name, e.g. stardust-2.5-max, deepseek-v3, gpt-4"
            },
            "modalities": {
              "type": "array",
              "items": { "type": "string", "enum": ["text", "audio", "video"] }
            },
            "instructions": {
              "oneOf": [
                { "type": "string" },
                { "type": "object" }
              ],
              "description": "System prompt. String supports {{variable}} syntax. Object type for ext_config."
            },
            "ext_config": {
              "type": "object",
              "properties": {
                "provider": { "type": "string" },
                "model_name": { "type": "string" },
                "model_url": { "type": "string", "format": "uri" },
                "api_key": { "type": "string" }
              }
            },
            "include_initial_prompt": {
              "type": ["string", "null"],
              "enum": ["first", "last", null]
            },
            "initial_user_prompt": { "type": "string" },
            "initial_assistant_prompt": { "type": "string" },
            "history_conversation_length": {
              "type": "integer",
              "minimum": 0,
              "maximum": 30
            },
            "tools": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "object",
                    "description": "Function tool definition",
                    "required": ["type", "name", "description", "parameters"],
                    "properties": {
                      "type": { "type": "string", "const": "function" },
                      "name": {
                        "type": "string",
                        "pattern": "^[a-z0-9_]+$"
                      },
                      "description": { "type": "string" },
                      "parameters": {
                        "type": "object",
                        "required": ["type", "properties"],
                        "properties": {
                          "type": { "type": "string", "const": "object" },
                          "properties": {
                            "type": "object",
                            "additionalProperties": {
                              "type": "object",
                              "properties": {
                                "type": { "type": "string", "enum": ["string", "number", "integer", "boolean"] },
                                "description": { "type": "string" },
                                "enum": { "type": "array" }
                              },
                              "required": ["type"]
                            }
                          },
                          "required": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        }
                      },
                      "code": { "type": "string" },
                      "language": { "type": "string", "enum": ["python", "shell"] },
                      "platform": { "type": "string", "default": "linux" },
                      "operation_mode": {
                        "type": "string",
                        "enum": ["client_mode", "server_mode", "mcp_mode"],
                        "default": "client_mode"
                      },
                      "execution_type": {
                        "type": "string",
                        "enum": ["synchronous", "asynchronous"],
                        "default": "synchronous"
                      },
                      "result_handling": {
                        "type": "string",
                        "enum": ["process_in_client", "process_in_llm", "ignore_result"],
                        "default": "process_in_client"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "description": "MCP server tool definition",
                    "required": ["type", "server_label"],
                    "properties": {
                      "type": { "type": "string", "const": "mcp" },
                      "server_label": { "type": "string" },
                      "server_url": { "type": "string", "format": "uri" },
                      "connector_id": { "type": "string" },
                      "server_description": { "type": "string" },
                      "allowed_tools": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "require_approval": {
                        "type": ["string", "null"],
                        "enum": ["always", null]
                      },
                      "authorization": { "type": "string" },
                      "headers": {
                        "type": "object",
                        "additionalProperties": { "type": "string" }
                      }
                    }
                  }
                ]
              }
            },
            "tool_choice": {
              "type": "string",
              "description": "auto/none/required or a specific function name"
            },
            "use_inner_tools": { "type": "boolean", "default": false },
            "use_inner_view_tools": { "type": "boolean", "default": true },
            "emotion_classifier": { "type": ["string", "null"] },
            "temperature": {
              "type": "number",
              "minimum": 0.01,
              "maximum": 1.0
            },
            "top_p": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "top_k": {
              "type": "integer",
              "minimum": 1
            },
            "max_response_output_tokens": {
              "type": "integer",
              "default": 4096
            },
            "messages": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["role", "content"],
                  "properties": {
                    "role": { "type": "string", "enum": ["system", "user", "assistant"] },
                    "content": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "speech": {
          "type": "object",
          "properties": {
            "provider": { "type": ["string", "null"] },
            "voice": { "type": "string" },
            "output_audio_format": { "type": "string", "const": "pcm16" },
            "emotion": {
              "type": "string",
              "enum": ["happy", "sad", "angry", "surprised", "fearful", "disgusted", "neutral"]
            },
            "speed_ratio": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 },
            "pitch_ratio": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 },
            "volume_ratio": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 }
          }
        },
        "hearing": {
          "type": "object",
          "properties": {
            "provider": { "type": ["string", "null"] },
            "input_audio_format": { "type": "string", "default": "pcm16" },
            "turn_detection": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string", "const": "server_vad" },
                    "threshold": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.09 },
                    "prefix_padding_ms": { "type": "integer", "default": 300 },
                    "silence_duration_ms": { "type": "integer", "default": 520 }
                  }
                }
              ]
            },
            "turn_voiceprint": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "properties": {
                    "use": { "type": "boolean", "default": false },
                    "type": { "type": "string", "enum": ["group", "single"] },
                    "group_id": { "type": "string" },
                    "profile_id": { "type": "string" },
                    "threshold": { "type": "number", "minimum": 0, "maximum": 100, "default": 75 }
                  }
                }
              ]
            }
          }
        },
        "vision": {
          "type": "object",
          "properties": {
            "enable_face_detection": { "type": "boolean", "default": false },
            "enable_face_identification": { "type": "boolean", "default": false },
            "enable_gesture_detection": { "type": "boolean", "default": false },
            "enable_object_detection": { "type": "boolean", "default": false },
            "object_detection_target_classes": {
              "type": ["array", "null"],
              "items": {
                "type": "string",
                "enum": [
                  "person", "bicycle", "car", "motorcycle", "airplane", "bus", "train", "truck",
                  "boat", "traffic light", "fire hydrant", "stop sign", "parking meter", "bench",
                  "bird", "cat", "dog", "horse", "sheep", "cow", "elephant", "bear", "zebra",
                  "giraffe", "backpack", "umbrella", "handbag", "tie", "suitcase", "frisbee",
                  "skis", "snowboard", "sports ball", "kite", "baseball bat", "baseball glove",
                  "skateboard", "surfboard", "tennis racket", "bottle", "wine glass", "cup",
                  "fork", "knife", "spoon", "bowl", "banana", "apple", "sandwich", "orange",
                  "broccoli", "carrot", "hot dog", "pizza", "donut", "cake", "chair", "couch",
                  "potted plant", "bed", "dining table", "toilet", "tv", "laptop", "mouse",
                  "remote", "keyboard", "cell phone", "microwave", "oven", "toaster", "sink",
                  "refrigerator", "book", "clock", "vase", "scissors", "teddy bear",
                  "hair drier", "toothbrush"
                ]
              }
            },
            "face_album_id": { "type": ["string", "null"] }
          }
        },
        "knowledge": {
          "type": "object",
          "properties": {
            "memories": {
              "type": "object",
              "properties": {
                "enable": { "type": "boolean", "default": false }
              }
            },
            "scripts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "name", "priority", "dialogues"],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "priority": { "type": "integer", "minimum": 1, "maximum": 10 },
                  "dialogues": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id", "prompts", "responses"],
                      "properties": {
                        "id": { "type": "string" },
                        "prompts": {
                          "type": "array",
                          "items": { "type": "string" },
                          "minItems": 1
                        },
                        "responses": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "required": ["id", "type"],
                            "properties": {
                              "id": { "type": "string" },
                              "type": { "type": "string", "enum": ["string", "label", "function"] },
                              "message": { "type": "string" },
                              "label": { "type": "string" },
                              "function": { "type": "string" },
                              "arguments": { "type": "object" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "retrieval": {
              "type": "object",
              "properties": {
                "enable": { "type": "boolean", "default": false },
                "knowledge_base_ids": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "retrieval_strategy": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string", "enum": ["vector", "keyword", "hybrid"] },
                    "top_k": { "type": "integer" },
                    "score_threshold": { "type": "number" }
                  }
                }
              }
            }
          }
        },
        "webhook": {
          "type": "object",
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "timeout": { "type": "integer", "default": 5 },
            "retry_times": { "type": "integer", "default": 0 },
            "events": {
              "type": "array",
              "items": { "type": "string", "enum": ["response.done.ext", "error"] }
            },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "custom_fields": { "type": "object" },
            "enabled": { "type": "boolean", "default": false }
          }
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "event", "actions"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "enabled": { "type": "boolean", "default": true },
              "event": {
                "type": "string",
                "enum": [
                  "PERCEPTION_FACE_APPEARED",
                  "PERCEPTION_FACE_DISAPPEARED",
                  "PERCEPTION_FACE_RECOGNIZED",
                  "PERCEPTION_GESTURE_DETECTED",
                  "PERCEPTION_OBJECT_DETECTED"
                ]
              },
              "conditions": {
                "type": "object",
                "properties": {
                  "is_known": { "type": "boolean" },
                  "cooldown_seconds": { "type": "integer" },
                  "gesture_type": { "type": "string" },
                  "object_class": { "type": "string" }
                }
              },
              "actions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["type"],
                  "properties": {
                    "type": { "type": "string", "enum": ["tts", "function_call", "event"] },
                    "template": { "type": "string" },
                    "function": { "type": "string" },
                    "arguments": { "type": "object" },
                    "event_type": { "type": "string" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          }
        },
        "extra": {
          "type": "object",
          "description": "Custom passthrough configuration"
        }
      }
    }
  }
}
